{
  "$id": "https://mibig.secondarymetabolites.org/schemas/common",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "citation": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^pubmed:(\\d+)$"
        },
        {
          "pattern": "^doi:10\\.\\d{4,9}/[-\\._;()/:a-zA-Z0-9]+$"
        },
        {
          "pattern": "^patent:(.+)$"
        },
        {
          "pattern": "^url:https?:\\/\\/(www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{2,256}\\.[a-z]{2,6}\\b([-a-zA-Z0-9@:%_\\+.~#?&//=]*)$"
        }
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "number",
          "minimum": 1
        },
        "to": {
          "type": "number",
          "minimum": 2
        }
      },
      "required": ["from", "to"]
    }
  }
}
