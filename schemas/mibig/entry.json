{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/entry",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "accession": {
      "$ref": "#/$defs/entryId"
    },
    "changelog": {
      "$ref": "/schemas/common/changelog"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "completeness": {
      "$ref": "#/$defs/completeness"
    },
    "loci": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/locus"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "retirementReasons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "seeAlso": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entryId"
      },
      "uniqueItems": true
    },
    "biosynthesis": {
      "$ref": "/schemas/mibig/biosynthesis/biosynthesis"
    },
    "compounds": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/compound"
      },
      "uniqueItems": true
    },
    "taxonomy": {
      "$ref": "/schemas/mibig/taxonomy"
    }
  },
  "$defs": {
    "completeness": {
      "type": "string",
      "enum": ["unknown", "incomplete", "complete"]
    },
    "entryId": {
      "type": "string",
      "format": "BGC\\d{7,7}"
    },
    "quality": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "embargoed", "active", "retired"]
    }
  }
}
