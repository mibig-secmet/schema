{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/entry.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "accession": {
      "$ref": "#/$defs/entryId"
    },
    "changelog": {
      "$ref": "/schemas/common/changelog.json"
    },
    "quality": {
      "$ref": "#/$defs/quality"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "completeness": {
      "$ref": "#/$defs/completeness"
    },
    "loci": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/locus.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "genes": {
      "$ref": "/schemas/mibig/genes.json"
    },
    "retirementReasons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "seeAlso": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entryId"
      },
      "uniqueItems": true
    },
    "biosynthesis": {
      "$ref": "/schemas/mibig/biosynthesis/biosynthesis.json"
    },
    "compounds": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/compound.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "taxonomy": {
      "$ref": "/schemas/mibig/taxonomy.json"
    },
    "comment": {
      "type": "string"
    }
  },
  "$defs": {
    "completeness": {
      "type": "string",
      "enum": ["unknown", "incomplete", "complete"]
    },
    "entryId": {
      "type": "string",
      "format": "BGC\\d{7,7}"
    },
    "quality": {
      "type": "string",
      "enum": ["questionable", "low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "embargoed", "active", "retired"]
    }
  },
  "required": [
    "accession",
    "changelog",
    "quality",
    "status",
    "completeness",
    "loci",
    "biosynthesis",
    "compounds",
    "taxonomy"
  ]
}
