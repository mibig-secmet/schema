{
  "$id": "https://meta.secondarymetabolites.org/schemas/gene_domains",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "location": {
      "$ref": "/schemas/common/$defs/location"
    },
    "name": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["location"],
  "$defs": {
    "substrates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "/schema/mibig/common/substrate_evidence"
            }
          },
          "structure": {
            "$ref": "/schemas/common/smiles"
          }
        },
        "required": ["evidence", "structure"]
      }
    }
  }
}
