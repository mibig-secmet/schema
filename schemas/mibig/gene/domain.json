{
  "$id": "https://meta.secondarymetabolites.org/schemas/gene_domains.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "location": {
      "$ref": "/schemas/common/location.json"
    },
    "name": {
      "type": "string"
    },
    "substrates": {
      "$ref": "#/$defs/substrates"
    }
  },
  "required": ["location", "name"],
  "$defs": {
    "substrates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "/schema/mibig/common/substrate_evidence.json"
            }
          },
          "structure": {
            "$ref": "/schemas/common/smiles.json"
          }
        },
        "required": ["evidence", "structure"]
      }
    }
  }
}
