{
  "$id": "https://meta.secondarymetabolites.org/schemas/gene_function.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "function": {
      "$ref": "#/$defs/function"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "mutation_phenotype": {
      "$ref": "#/$defs/mutation_phenotype"
    }
  },
  "required": ["function", "evidence"],
  "$defs": {
    "function": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "Activation / processing",
            "Maturation",
            "Precursor",
            "Precursor biosynthesis",
            "Regulation",
            "Resistance/immunity",
            "Scaffold biosynthesis",
            "Tailoring",
            "Transport",
            "Other"
          ]
        },
        "details": {
          "type": "string"
        }
      },
      "required": ["name"]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "Other in vivo study",
            "Heterologous expression",
            "Knock-out",
            "Activity assay"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["method", "references"]
    },
    "mutation_phenotype": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phenotype": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "references": {
          "$ref": "/schemas/common/citation.json"
        }
      }
    }
  }
}
