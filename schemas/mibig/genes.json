{
  "$id": "https://meta.secondarymetabolites.org/schemas/genes.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "toAdd": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/addition"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "toDelete": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deletion"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "annotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/annotation"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "domains": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/gene/domain.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "addition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "/schemas/common/gene_id.json"
        },
        "location": {
          "$ref": "#/$defs/geneLocation"
        },
        "translation": {
          "type": "string"
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "/schemas/common/gene_id.json"
        },
        "name": {
          "$ref": "/schemas/common/gene_id.json"
        },
        "product": {
          "type": "string"
        },
        "functions": {
          "type": "array",
          "items": {
            "$ref": "/schemas/mibig/gene/function.json"
          }
        },
        "tailoring": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tailoringFunction"
          },
          "uniqueItems": true
        }
      },
      "required": ["id"]
    },
    "deletion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "geneLocation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exons": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/location.json"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "strand": {
          "type": "number",
          "enum": [-1, 1]
        }
      },
      "required": ["exons", "strand"]
    },
    "tailoringFunction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "function": {
          "type": "string",
          "enum": [
            "Acetylation",
            "Acylation",
            "Amination",
            "Biaryl bond formation",
            "Carboxylation",
            "Cyclization",
            "Deamination",
            "Decarboxylation",
            "Dehydration",
            "Dehydrogenation",
            "Demethylation",
            "Dioxygenation",
            "Epimerization",
            "FADH2 supply for chlorination",
            "Glycosylation",
            "Halogenation",
            "Heterocyclization",
            "Hydrolysis",
            "Hydroxylation",
            "Lasso macrolactam formation",
            "Methylation",
            "Monooxygenation",
            "Oxidation",
            "Phosphorylation",
            "Prenylation",
            "Reduction",
            "Sulfation",
            "Other"
          ]
        },
        "details": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dbReference": {
          "type": "string",
          "pattern": "^MITE(\\d)+$"
        }
      },
      "required": ["function", "references"]
    }
  }
}
