{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/saccharide.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "class": {
      "const": "saccharide"
    },
    "glycosyltransferases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/glycosyltransferase"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "subclass": {
      "type": "string",
      "enum": []
    },
    "subclusters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subcluster"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["glycosyltransferases"],
  "$defs": {
    "glycosyltransferase": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "enum": [
                "Sequence-based prediction",
                "Structure-based inference",
                "Knock-out construct",
                "Activity assay"
              ]
            },
            "references": {
              "type": "array",
              "items": {
                "$ref": "/schemas/common/citation.json"
              },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "required": ["name", "references"]
        },
        "gene": {
          "$ref": "/schemas/common/gene_id.json"
        },
        "specificity": {
          "$ref": "/schemas/common/smiles.json"
        }
      },
      "required": ["gene", "evidence"]
    },
    "subcluster": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "specificity": {
          "$ref": "/schemas/common/smiles.json"
        },
        "genes": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/gene_id.json"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
