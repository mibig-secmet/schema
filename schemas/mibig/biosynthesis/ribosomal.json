{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/ribosomal.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "class": {
      "const": "ribosomal"
    },
    "subclass": {
      "enum": ["RiPP", "unmodified"]
    },
    "ripp_type": {
      "type": "string",
      "enum": [
        "Atropopeptide",
        "Biarylitide",
        "Bottromycin",
        "Borosin",
        "Crocagin",
        "Cyanobactin",
        "Cyptide",
        "Dikaritin",
        "Epipeptide",
        "Glycocin",
        "Graspetide",
        "Guanidinotide",
        "Head-to-tail cyclized peptide",
        "Lanthipeptide",
        "LAP",
        "Lasso peptide",
        "Linaridin",
        "Methanobactin",
        "Microcin",
        "Microviridin",
        "Mycofactocin",
        "Pearlin",
        "Proteusin",
        "Ranthipeptide",
        "Rotapeptide",
        "Ryptide",
        "Sactipeptide",
        "Spliceotide",
        "Streptide",
        "Sulfatyrotide",
        "Thioamidide",
        "Thiopeptide",
        "Other"
      ]
    },
    "details": {
      "type": "string"
    },
    "peptidases": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/gene_id.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "precursors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/precursor"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["class", "subclass", "precursors"],
  "$defs": {
    "precursor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gene": {
          "$ref": "/schemas/common/gene_id.json"
        },
        "core_sequence": {
          "type": "string"
        },
        "leader_cleavage_location": {
          "$ref": "/schemas/common/location.json"
        },
        "follower_cleavage_location": {
          "$ref": "/schemas/common/location.json"
        },
        "crosslinks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "number",
                "minimum": 1
              },
              "to": {
                "type": "number",
                "minimum": 2
              },
              "type": {
                "type": "string",
                "enum": ["ether", "thioether", "other"]
              },
              "details": {
                "type": "string"
              }
            }
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "recognition_motif": {
          "type": "string"
        }
      },
      "required": ["gene", "core_sequence"]
    }
  }
}
