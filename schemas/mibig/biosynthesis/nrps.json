{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/nrps.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "class": {
      "const": "NRPS"
    },
    "subclass": {
      "type": "string",
      "enum": ["Type I", "Type II", "Type III", "Type IV", "Type V", "Type VI"]
    },
    "release_type": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/common/release_type.json"
      },
      "uniqueItems": true
    },
    "thioesterases": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/common/thioesterase.json"
      },
      "uniqueItems": true
    }
  },
  "required": ["class", "subclass"]
}
