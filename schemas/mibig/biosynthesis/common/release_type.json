{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/common/release_type.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "enum": [
        "Claisen condensation",
        "Hydrolysis",
        "Macrolactamization",
        "Macrolactonization",
        "None",
        "Other",
        "Reductive release"
      ]
    },
    "details": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/citation.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["name"]
}
