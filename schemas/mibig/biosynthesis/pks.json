{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/pks",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "class": {
      "const": "pks"
    },
    "subclass": {
      "type": "string",
      "enum": [
        "Type I",
        "Type II aromatic",
        "Type II highly reducing",
        "Type II arylpolyene",
        "Type III"
      ]
    },
    "cyclases": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/gene_id.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "starter_unit": {
      "$ref": "#/$defs/starter_unit"
    },
    "ketide_length": {
      "type": "integer",
      "minimum": 0
    },
    "iterative": {
      "$ref": "#/$defs/iterative"
    },
    "thioesterases": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/domains/thioesterase.json"
      },
      "uniqueItems": true
    }
  },
  "required": ["class", "subclass"],
  "$defs": {
    "starter_unit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "iterative": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    }
  }
}
