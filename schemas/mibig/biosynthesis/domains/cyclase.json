{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/domains/cyclase.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "cyclase"
    },
    "gene": {
      "$ref": "/schemas/common/gene_id.json"
    },
    "location": {
      "$ref": "/schemas/common/location.json"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/citation.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["type", "gene", "location"]
}
