{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/domains/acyltransferase.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "acyltransferase"
    },
    "subtype": {
      "type": "string",
      "enum": ["cis-AT", "trans-AT"]
    },
    "gene": {
      "$ref": "/schemas/common/gene_id.json"
    },
    "location": {
      "$ref": "/schemas/common/location.json"
    },
    "inactive": {
      "type": "boolean"
    },
    "substrates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/substrate"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/common/substrate_evidence.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["type", "gene", "location"],
  "$defs": {
    "substrate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "malonyl-CoA",
            "methylmalonyl-CoA",
            "ethylmalonyl-CoA",
            "other"
          ]
        },
        "details": {
          "type": "string"
        },
        "structure": {
          "$ref": "/schemas/common/smiles.json"
        }
      },
      "required": ["name"]
    }
  }
}
