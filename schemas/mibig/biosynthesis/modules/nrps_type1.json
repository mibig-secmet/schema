{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/modules/nrps_type1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "active": {
      "type": "boolean"
    },
    "c_domain": {
      "$ref": "/schemas/mibig/biosynthesis/modules/domains/condensation"
    },
    "a_domain": {
      "$ref": "/schemas/mibig/biosynthesis/modules/domains/adenylation"
    },
    "carriers": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/modules/domains/carrier"
      }
    },
    "comments": {
      "type": "string"
    },
    "genes": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/gene_id"
      }
    },
    "integrated_monomers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/monomer"
      },
      "uniqueItems": true
    },
    "modification_domains": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "/schemas/mibig/biosynthesis/modules/domains/aminotransferase"
          },
          { "$ref": "/schemas/mibig/biosynthesis/modules/domains/cyclase" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/domains/dehydratase" },
          {
            "$ref": "/schemas/mibig/biosynthesis/modules/domains/enoylreductase"
          },
          { "$ref": "/schemas/mibig/biosynthesis/modules/domains/epimerase" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/domains/hydroxylase" },
          {
            "$ref": "/schemas/mibig/biosynthesis/modules/domains/ketoreductase"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/modules/domains/methyltransferase"
          },
          { "$ref": "/schemas/mibig/biosynthesis/modules/domains/other" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/domains/oxidase" }
        ]
      }
    },
    "name": {
      "type": "string"
    }
  }
}
