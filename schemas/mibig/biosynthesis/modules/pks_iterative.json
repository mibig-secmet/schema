{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/modules/pks_iterative.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "pks-iterative"
    },
    "active": {
      "type": "boolean"
    },
    "ks_domain": {
      "$ref": "/schemas/mibig/biosynthesis/domains/ketosynthase.json"
    },
    "at_domain": {
      "$ref": "/schemas/mibig/biosynthesis/domains/acyltransferase.json"
    },
    "carriers": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/domains/carrier.json"
      }
    },
    "comments": {
      "type": "string"
    },
    "genes": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/gene_id.json"
      }
    },
    "integrated_monomers": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/common/monomer.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "iterations": {
      "type": "number"
    },
    "modification_domains": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/aminotransferase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/cyclase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/dehydratase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/enoylreductase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/epimerase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/hydroxylase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/ketoreductase.json"
          },
          {
            "$ref": "/schemas/mibig/biosynthesis/domains/methyltransferase.json"
          },
          { "$ref": "/schemas/mibig/biosynthesis/domains/other.json" },
          { "$ref": "/schemas/mibig/biosynthesis/domains/oxidase.json" }
        ]
      }
    },
    "name": {
      "type": "string"
    }
  },
  "required": ["type", "name", "genes", "active", "iterations"]
}
