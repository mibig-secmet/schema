{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/biosynthesis.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "classes": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "/schemas/mibig/biosynthesis/nrps.json" },
          { "$ref": "/schemas/mibig/biosynthesis/other.json" },
          { "$ref": "/schemas/mibig/biosynthesis/pks.json" },
          { "$ref": "/schemas/mibig/biosynthesis/ribosomal.json" },
          { "$ref": "/schemas/mibig/biosynthesis/saccharide.json" },
          { "$ref": "/schemas/mibig/biosynthesis/terpene.json" }
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "modules": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "/schemas/mibig/biosynthesis/modules/cal" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/nrps_type1" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/nrps_type6" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/other" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/pks_iterative" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/pks_modular" },
          { "$ref": "/schemas/mibig/biosynthesis/modules/pks_trans_at" }
        ]
      },
      "minItems": 1
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/path/path.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["classes", "paths"]
}
