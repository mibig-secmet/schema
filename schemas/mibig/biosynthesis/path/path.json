{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/path/path",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/path/step"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/citation.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["products", "steps", "references"]
}
