{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/biosynthesis/path/path.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "$ref": "/schemas/mibig/biosynthesis/path/product.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "steps": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "/schemas/common/citation.json"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "isSubcluster": {
      "type": "boolean"
    },
    "producesPrecursor": {
      "type": "boolean"
    }
  },
  "required": [
    "products",
    "steps",
    "references",
    "isSubcluster",
    "producesPrecursor"
  ]
}
