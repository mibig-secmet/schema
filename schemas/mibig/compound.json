{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/compound.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "name": {
      "$ref": "#/$defs/name"
    },
    "classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/class"
      },
      "uniqueItems": true
    },
    "bioactivities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bioactivity"
      }
    },
    "cyclic": {
      "type": "boolean"
    },
    "moieties": {
      "type": "array"
    },
    "structure": {
      "$ref": "/schemas/common/smiles.json"
    },
    "partial_structure": {
      "type": "boolean"
    },
    "synonyms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/name"
      },
      "uniqueItems": true
    },
    "targets": {
      "type": "array"
    },
    "databaseIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/databaseId"
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "mass": {
      "type": "number"
    },
    "formula": {
      "type": "string"
    }
  },
  "required": ["name", "evidence"],
  "$defs": {
    "assay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "measurement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "concentration": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            },
            "error": {
              "type": "number"
            },
            "replicates": {
              "type": "number"
            }
          }
        },
        "type": {
        },
        "target": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "test_system": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cell_line": {
              "type": "string"
            },
            "organism": {
              "type": "number"
            },
            "strain": {
              "type": "string"
            }
          },
          "required": []
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["concentration", "target"]
    },
    "bioactivity": {
      "type": "object",
      "extra_properties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "observed": {
          "type": "boolean"
        },
        "assays": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/assay"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["name", "observed", "references"]
    },
    "class": {
      "type": "string",
      "enum": ["alkaloid", "nucleoside", "peptide"]
    },
    "databaseId": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^pubchem:(\\d+)$"
        },
        {
          "pattern": "^chebi:(\\d+)$"
        },
        {
          "pattern": "^chembl:CHEMBL(\\d+)$"
        },
        {
          "pattern": "^chemspider:(\\d+)$"
        },
        {
          "pattern": "^npatlas:NPA(\\d+)$"
        },
        {
          "pattern": "^lotus:Q(\\d+)$"
        },
        {
          "pattern": "^gnps:MSV(\\d+)$"
        },
        {
          "pattern": "^cyanometdb:CyanoMetDB_(\\d{4,4})$"
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "NMR",
            "Mass spectrometry",
            "MS/MS",
            "X-ray crystallography",
            "Chemical derivatisation",
            "Total synthesis"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["method", "references"]
    },
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Zα-ωΑ-Ω0-9\\[\\]'()/&,. +-]+$"
    }
  }
}
