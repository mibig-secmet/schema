{
  "$id": "https://meta.secondarymetabolites.org/schemas/mibig/compound.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "name": {
      "$ref": "#/$defs/name"
    },
    "classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/class"
      },
      "uniqueItems": true
    },
    "bioactivities": {
      "type": "array"
    },
    "cyclic": {
      "type": "boolean"
    },
    "moieties": {
      "type": "array"
    },
    "structure": {
      "$ref": "/schemas/common/smiles.json"
    },
    "synonyms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/name"
      },
      "uniqueItems": true
    },
    "targets": {
      "type": "array"
    },
    "databaseIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/databaseId"
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "mass": {
      "type": "number"
    },
    "ionType": {
      "$ref": "#/$defs/ionType"
    },
    "formula": {
      "type": "string"
    }
  },
  "required": ["name", "evidence"],
  "$defs": {
    "class": {
      "type": "string",
      "enum": ["alkaloid", "nucleoside", "peptide"]
    },
    "databaseId": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^pubchem:(\\d+)$"
        },
        {
          "pattern": "^chebi:(\\d+)$"
        },
        {
          "pattern": "^chembl:CHEMBL(\\d+)$"
        },
        {
          "pattern": "^chemspider:(\\d+)$"
        },
        {
          "pattern": "^npatlas:NPA(\\d+)$"
        },
        {
          "pattern": "^lotus:Q(\\d+)$"
        },
        {
          "pattern": "^gnps:MSV(\\d+)$"
        },
        {
          "pattern": "^cyanometdb:CyanoMetDB_(\\d{4,4})$"
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "NMR",
            "Mass spectrometry",
            "MS/MS",
            "X-ray crystallography",
            "Chemical derivatisation",
            "Total synthesis"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["method", "references"]
    },
    "ionType": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ion": {
          "type": "string",
          "enum": ["[M+H]+", "[M-H]-", "[M+Na]+", "[2M+Na]+", "[2M+H]+", "[M+2H]2+", "[M+3H]3+", "[M+56Fe-2H]+", "[M+NH4]+", "[M+K]+", "[M+H2O+H]+", "other"]
        },
        "details": {
          "type": "string"
        }
      },
      "required": ["ion"],
      "if": {
        "properties": {
          "ion": {
            "const": "other"
          }
        }
      },
      "then": {
        "required": ["details"]
      }
    },
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Zα-ωΑ-Ω0-9\\[\\]'()/&,. +-]+$"
    }
  }
}
