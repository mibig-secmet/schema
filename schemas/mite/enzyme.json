{
  "$id": "https://meta.secondarymetabolites.org/schemas/mite/enzyme.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "type": "object",
  "properties": {
    "name": {
      "title": "Protein name, e.g. 'NisB'.",
      "type": "string"
    },
    "description": {
      "title": "Brief description of the enzyme function.",
      "type": "string"
    },
    "databaseIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/databaseId"
      },
      "uniqueItems": true
    },
    "auxiliary_enzymes": {
      "title": "Specify any required auxiliary enzymes that are co-forming the maturation machinery.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "title": "Protein name, e.g. 'NisC'.",
            "type": "string"
          },
          "description": {
            "title": "Brief description of function.",
            "type": "string"
          },
          "databaseIds": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/databaseId"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["name", "databaseIds", "evidence"],
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidenceCode": {
          "title": "Evidence for protein existence. Adapted from https://www.uniprot.org/help/protein_existence.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "Experimental evidence at protein level",
              "Experimental evidence at transcript level",
              "Protein inferred from homology"
            ]
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["evidenceCode", "references"]
    },
    "databaseId": {
      "type": "string",
      "oneOf": [
        {
          "title": "Uniprot ID reference.",
          "pattern": "^uniprot:[A-Z0-9]+$"
        },
        {
          "title": "GenBank GenPept ID (= protein ID, GenBank gene products)",
          "pattern": "^genpept:[A-Z]{3}[0-9]{5,7}\\.[0-9]+$"
        }
      ]
    }
  }
}
