{
  "$id": "https://meta.secondarymetabolites.org/schemas/mite/reactions.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "required": ["tailoring", "reactionCXSMARTS", "validated_reactions", "evidence"],
  "properties": {
    "tailoring": {
      "title": "Ontology-derived tailoring/maturation reaction term.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/tailoringFunction"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "description": {
      "title": "Additional information about tailoring/maturation reaction.",
      "type": "string"
    },
    "reactionCXSMARTS": {
      "title": "A reaction CXSMARTS (Chemaxon SMARTS) pattern describing the (sub)structure to match and the reaction to perform.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reactionCXSMARTS": {
          "title": "The CXSMARTS string",
          "type": "string",
          "pattern": "^.+>>.+$"
        },
        "isIterative": {
          "title": "Flag to indicate if the reaction is applied iteratively (modifying all possible substructures).",
          "type": "boolean"
        },
        "hasLinker": {
          "title": "Flag to indicate if the reaction contains a Link group to represent repeating units of variable length (e.g. a C-chain of variable length).",
          "type": "boolean"
        },
        "hasPositionVariationBond": {
          "title": "Flag to indicate if the reaction contains a position variation bond which indicates positional variation of a substituent over multiple atoms (e.g. variable chlorination on an aromatic ring).",
          "type": "boolean"
        },
        "explicitHydrogen": {
          "title": "On substrate site of reaction, indicate atom with explicit hydrogen atoms (e.g. an amine with two hydrogens).",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "index": {
                "title": "The atom index",
                "type": "integer"
              },
              "nrHydrogens": {
                "title": "The number of explicit hydrogen atoms on this atom",
                "type": "integer"
              }
            }
          }
        }
      },
      "required": [
        "reactionCXSMARTS",
        "isIterative",
        "hasLinker",
        "hasPositionVariationBond"
      ]
    },
    "validated_reactions": {
      "type": "array",
      "title": "One or more substrate (sub)structure -> product (sub)structure pairs that result from application of reactionCXSMARTS.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "substrate_(sub)structure": {
            "$ref": "/schemas/common/smiles.json"
          },
          "product_(sub)structure": {
            "type": "array",
            "title": "One or more product (sub)structures",
            "minItems": 1,
            "items": {
              "$ref": "/schemas/common/smiles.json"
            }
          },
          "isBalanced": {
            "title": "Is the validated reaction balanced (i.e. stoichiometric complete)?",
            "type": "boolean"
          },
          "isAuthentic": {
            "title": "Is this substrate-product pair authentic/experimentally verified (i.e. not substructures)",
            "type": "boolean"
          },
          "isIntermediate": {
            "title": "Is this validated reaction an intermediate step (i.e. not the final product)?",
            "type": "boolean"
          },
          "description": {
            "title": "Additional information about reaction example",
            "type": "string"
          }
        },
        "required": [
          "substrate_(sub)structure",
          "product_(sub)structure",
          "isBalanced",
          "isAuthentic",
          "isIntermediate"
        ]
      }
    },
    "databaseIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/databaseId"
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "tailoringFunction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "function": {
          "type": "string",
          "enum": [
            "Acetylation",
            "Acylation",
            "Amination",
            "Biaryl bond formation",
            "Carboxylation",
            "Cyclization",
            "Deamination",
            "Decarboxylation",
            "Dehydration",
            "Dehydrogenation",
            "Demethylation",
            "Dioxygenation",
            "Epimerization",
            "FADH2 supply for chlorination",
            "Glycosylation",
            "Halogenation",
            "Heterocyclization",
            "Hydrolysis",
            "Hydroxylation",
            "Macrolactam formation",
            "Methylation",
            "Monooxygenation",
            "Oxidation",
            "Phosphorylation",
            "Prenylation",
            "Reduction",
            "Sulfation",
            "Other"
          ]
        },
        "details": {
          "type": "string"
        }
      },
      "required": ["function"]
    },
    "databaseId": {
      "title": "Cross-reference to other databases.",
      "type": "string",
      "oneOf": [
        {
          "pattern": "^rhea:(\\d+)$"
        },
        {
          "pattern": "^MITE(\\d{7,7})$"
        },
        {
          "pattern": "^EC [0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]$"
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidenceCode": {
          "title": "Evidence for reaction and substrate specificity",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "Enzymatic assays",
              "Heterologous expression",
              "In vitro determination",
              "Isothermal titration calorimetry",
              "Knock-out studies",
              "NMR",
              "Site-directed mutagenesis",
              "Surface plasmon resonance",
              "(Tandem) mass spectrometry",
              "X-ray crystallography"
            ]
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "/schemas/common/citation.json"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["evidenceCode", "references"]
    }
  }
}
