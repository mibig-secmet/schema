{
  "$id": "https://meta.secondarymetabolites.org/schemas/common/changelog",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "releases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/release"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contributors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/submitter"
          }
        },
        "reviewers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/submitter"
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^(\\d+(\\.\\d+)*|next)$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entry"
          }
        }
      }
    },
    "submitter": {
      "type": "string",
      "minLength": 24,
      "maxLength": 24
    }
  }
}
